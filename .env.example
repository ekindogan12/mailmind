# MailMind Environment Variables
# Copy this to .env.local and fill in your values

# AI Features (optional - falls back to smart heuristics)
ANTHROPIC_API_KEY=

# Gmail OAuth (optional - uses demo mode without)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Office 365 OAuth (optional - uses demo mode without)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# App Config
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
