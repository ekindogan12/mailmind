generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Email {
  id          String   @id @default(uuid())
  accountId   String
  threadId    String
  from        String   // JSON stringified EmailParticipant
  to          String   // JSON stringified EmailParticipant[]
  subject     String
  snippet     String
  body        String
  date        String
  read        Boolean  @default(false)
  starred     Boolean  @default(false)
  labels      String   // JSON stringified string[]
  folder      String   @default("inbox")
  attachments String   // JSON stringified EmailAttachment[]
  priority    Int?
  aiCategory  String?
  aiSummary   String?  // JSON stringified summary object
  aiDrafts    String?  // JSON stringified drafts object
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  provider    String
  color       String
  unreadCount Int      @default(0)
  connected   Boolean  @default(true)
}
